PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/ai_assessment?retryWrites=true&w=majority

# Upstash Redis connection string (TLS — starts with rediss://)
# Format: rediss://:PASSWORD@HOST:PORT
UPSTASH_REDIS_URL=rediss://:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379
